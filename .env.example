# TypeScribe local environment
# Get a key from https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Optional overrides
# DEEPGRAM_MODEL=whisper-large
# DEEPGRAM_LANGUAGE=auto
# PORT=4177

# Optional: folder used by the local server for audio clip exports.
# If unset, TypeScribe uses a temp folder.
# TYPESCRIBE_MEDIA_DIR=C:\\Users\\you\\Music\\typescribe-media
